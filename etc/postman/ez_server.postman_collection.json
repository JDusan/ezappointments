                "key": "X-Username",
                "value": "{{xUsername}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{doctorUsername}}\",\n  \"firstName\": \"{{doctorFirstName}}\",\n  \"lastName\": \"{{doctorLastName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/doctor",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "doctor"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('doctorId', body.id);",
                  "  pm.collectionVariables.set('xUsername', body.username);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Doctor",
